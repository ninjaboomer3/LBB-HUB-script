-- LBB DESYNC — GALAXY EDITION
-- GUI is built first. RakNet detection runs after in a protected spawn.
-- Workflow: H = freeze server pos | T = snap server to real pos | H = unfreeze & steal

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer

local pg
local ok = pcall(function() pg = player:WaitForChild("PlayerGui", 10) end)
if not ok or not pg then return end

local old = pg:FindFirstChild("LBBDesync")
if old then old:Destroy() end

--// STATE
local desynced = false
local listening = nil
local keybinds = { toggle = Enum.KeyCode.H, teleport = Enum.KeyCode.T, panel = Enum.KeyCode.U }
local _pause, _resume, supported = nil, nil, false

local pulseEnabled = true
local PULSE_INTERVAL = 2
local PULSE_DURATION = 0.08
local pulseTimer = 0
local pulsing = false

--// GUI
local gui = Instance.new("ScreenGui")
gui.Name = "LBBDesync"
gui.ResetOnSpawn = false
gui.DisplayOrder = 99999
gui.IgnoreGuiInset = true
gui.Parent = pg

local main = Instance.new("Frame")
main.Size = UDim2.new(0, 260, 0, 300)
main.Position = UDim2.new(0.5, -130, 0.5, -150)
main.BackgroundColor3 = Color3.fromRGB(6, 4, 20)
main.BorderSizePixel = 0
main.Parent = gui
Instance.new("UICorner", main).CornerRadius = UDim.new(0, 18)

local border = Instance.new("UIStroke")
border.Color = Color3.fromRGB(90, 50, 200)
border.Thickness = 1.5
border.Parent = main

-- glow blobs
local function mkGlow(col, sz, x, y, tr)
    local g = Instance.new("ImageLabel")
    g.Size = UDim2.new(0, sz, 0, sz)
    g.Position = UDim2.new(0, x, 0, y)
    g.BackgroundTransparency = 1
    g.Image = "rbxassetid://5554236805"
    g.ImageColor3 = col
    g.ImageTransparency = tr
    g.ScaleType = Enum.ScaleType.Slice
    g.SliceCenter = Rect.new(23, 23, 277, 277)
    g.ZIndex = 2
    g.Parent = main
    return g
end
local glowP = mkGlow(Color3.fromRGB(100,40,220), 220, 60, -70, 0.42)
mkGlow(Color3.fromRGB(20, 80, 210), 190, -55, 160, 0.48)

-- stars
for i = 1, 20 do
    local s = Instance.new("Frame")
    s.Size = UDim2.new(0, 2, 0, 2)
    s.Position = UDim2.new(math.random(3,95)/100, 0, math.random(3,95)/100, 0)
    s.BackgroundColor3 = Color3.new(1,1,1)
    local b = math.random(2,5)/10
    s.BackgroundTransparency = b
    s.BorderSizePixel = 0
    s.ZIndex = 2
    s.Parent = main
    Instance.new("UICorner", s).CornerRadius = UDim.new(1, 0)
    local sf = s
    task.delay(i * 0.13, function()
        while true do
            TweenService:Create(sf, TweenInfo.new(1.4, Enum.EasingStyle.Sine), {BackgroundTransparency = 0.9}):Play()
            task.wait(1.4)
            TweenService:Create(sf, TweenInfo.new(1.4, Enum.EasingStyle.Sine), {BackgroundTransparency = b}):Play()
            task.wait(1.4)
        end
    end)
end

