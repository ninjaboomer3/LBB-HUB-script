--==================================================
-- LBB DESYNC — GALAXY EDITION
--
-- HOW RAKNET DESYNC WORKS:
-- raknetpause() tells the executor to stop flushing
-- outgoing UDP packets to Roblox's servers.
-- The server's last known position for your character
-- freezes. You can walk freely on your client.
-- raknetresume() flushes all held packets at once —
-- server snaps you to your real current position.
--
-- IMPORTANT: Executor functions like raknetpause live
-- in getgenv(), NOT getfenv(). This was the bug in
-- all previous versions of this script.
--==================================================

local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")

local player    = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

--==================================================
-- KEYBINDS
--==================================================
local keybinds = {
    toggle = Enum.KeyCode.H,
    panel  = Enum.KeyCode.U,
}

--==================================================
-- STATE
--==================================================
local desynced     = false
local listeningFor = nil

--==================================================
-- FIND RAKNET FUNCTIONS
-- getgenv() = executor's global environment (correct)
-- getfenv() = local script environment (WRONG, was bug)
-- Also try direct global access as final fallback
--==================================================
local genv = getgenv()

local _pause  = genv.raknetpause
             or genv.RakNetPause
             or genv.raknet_pause
             or genv.pauseraknet

local _resume = genv.raknetresume
             or genv.RakNetResume
             or genv.raknet_resume
             or genv.resumeraknet

-- Final fallback: try direct globals
if not _pause  then pcall(function() _pause  = raknetpause  end) end
if not _resume then pcall(function() _resume = raknetresume end) end

local supported = type(_pause) == "function" and type(_resume) == "function"

if supported then
    print("[LBB] ✅ RakNet found — desync ready")
else
    warn("[LBB] ❌ RakNet NOT found in getgenv()")
    warn("[LBB] Make sure Delta is fully up to date")
    warn("[LBB] Try running: print(type(getgenv().raknetpause)) in console to verify")
end

--==================================================
-- RAKNET CORE
--==================================================
local function pauseNet()
    if desynced then return end
    desynced = true
    local ok, err = pcall(_pause)
    if ok then
        print("[LBB] DESYNCED — server frozen at last position")
    else
        warn("[LBB] pauseNet failed: " .. tostring(err))
        desynced = false
    end
end

local function resumeNet()
    if not desynced then return end
    desynced = false
    local ok, err = pcall(_resume)
    if ok then
        print("[LBB] RESYNCED — server updated to real position")
    else
        warn("[LBB] resumeNet failed: " .. tostring(err))
    end
end

-- Auto cleanup on respawn
player.CharacterAdded:Connect(function(c)
    character = c
    if desynced then
        pcall(_resume)
        desynced = false
    end
    if updateUI then updateUI() end
end)

--==================================================
-- GUI ROOT
--==================================================
local gui = Instance.new("ScreenGui")
gui.Name         = "LBBDesync"
gui.ResetOnSpawn = false
gui.DisplayOrder = 99999
gui.Enabled      = true
gui.Parent       = player:WaitForChild("PlayerGui")

local main = Instance.new("Frame")
main.Size             = UDim2.new(0, 260, 0, 310)
main.Position         = UDim2.new(0.5, -130, 0.5, -155)
main.BackgroundColor3 = Color3.fromRGB(6, 4, 20)
main.BorderSizePixel  = 0
main.ZIndex           = 1
main.Parent           = gui
Instance.new("UICorner", main).CornerRadius = UDim.new(0, 18)

local mainBorder = Instance.new("UIStroke")
mainBorder.Color        = Color3.fromRGB(90, 50, 200)
mainBorder.Thickness    = 1.5
mainBorder.Transparency = 0.1
mainBorder.Parent       = main

--==================================================
-- GALAXY BG — ZIndex 2 (always behind UI)
--==================================================
local function makeGlow(col, sz, x, y, tr)
    local g = Instance.new("ImageLabel")
    g.Size             = UDim2.new(0, sz, 0, sz)
    g.Position         = UDim2.new(0, x, 0, y)
    g.BackgroundTransparency = 1
    g.Image            = "rbxassetid://5554236805"
    g.ImageColor3      = col
    g.ImageTransparency = tr
    g.ScaleType        = Enum.ScaleType.Slice
    g.SliceCenter      = Rect.new(23, 23, 277, 277)
    g.ZIndex           = 2
    g.Parent           = main
    return g
end

local glowPurple = makeGlow(Color3.fromRGB(100, 40, 220), 220,  60, -70, 0.42)
local glowBlue   = makeGlow(Color3.fromRGB(20,  80, 210), 190, -55, 180, 0.48)

-- Twinkling stars
local starList = {}
for i = 1, 22 do
    local s  = Instance.new("Frame")
    s.Size   = UDim2.new(0, (i % 3 == 0) and 3 or 2, 0, (i % 3 == 0) and 3 or 2)
    s.Position = UDim2.new(math.random(2, 96) / 100, 0, math.random(2, 96) / 100, 0)
    s.BackgroundColor3 = Color3.new(1, 1, 1)
    local bt = math.random(1, 4) / 10 + 0.1
    s.BackgroundTransparency = bt
    s.BorderSizePixel = 0
    s.ZIndex = 2
    s.Parent = main
    Instance.new("UICorner", s).CornerRadius = UDim.new(1, 0)
    table.insert(starList, {f = s, base = bt})
end
for i, sd in ipairs(starList) do
    task.delay(i * 0.11, function()
        while true do
            TweenService:Create(sd.f, TweenInfo.new(math.random(12, 30) / 10, Enum.EasingStyle.Sine),
                {BackgroundTransparency = math.min(sd.base + 0.55, 0.96)}):Play()
            task.wait(math.random(12, 30) / 10)
            TweenService:Create(sd.f, TweenInfo.new(math.random(12, 30) / 10, Enum.EasingStyle.Sine),
                {BackgroundTransparency = sd.base}):Play()
            task.wait(math.random(12, 30) / 10)
        end
    end)
end

-- Drifting orbs
for i, col in ipairs({
    Color3.fromRGB(140, 80, 255),
    Color3.fromRGB(60, 140, 255),
    Color3.fromRGB(200, 100, 255),
    Color3.fromRGB(80, 200, 255),
}) do
    local orb = Instance.new("Frame")
    orb.Size   = UDim2.new(0, math.random(4, 7), 0, math.random(4, 7))
    orb.Position = UDim2.new(math.random(10, 90) / 100, 0, math.random(10, 90) / 100, 0)
    orb.BackgroundColor3 = col
    orb.BackgroundTransparency = 0.25
    orb.BorderSizePixel = 0
    orb.ZIndex = 2
    orb.Parent = main
    Instance.new("UICorner", orb).CornerRadius = UDim.new(1, 0)
    task.delay(i * 0.4, function()
        while true do
            TweenService:Create(orb,
                TweenInfo.new(math.random(50, 110) / 10, Enum.EasingStyle.Sine),
                {Position = UDim2.new(math.random(5, 90) / 100, 0, math.random(5, 90) / 100, 0)}
            ):Play()
            task.wait(math.random(50, 110) / 10)
        end
    end)
end

