-- keybind rows — PC only
local keyRefs = {}
local function mkRow(lbl, key, y)
    if isMobile then return end
    local row = Instance.new("Frame")
    row.Size = UDim2.new(0, W - 40, 0, RS)
    row.Position = UDim2.new(0.5, -(W-40)/2, 0, y)
    row.BackgroundColor3 = Color3.fromRGB(10, 7, 28)
    row.BorderSizePixel = 0; row.ZIndex = 20; row.Parent = main
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 9)
    local rs = Instance.new("UIStroke"); rs.Color = Color3.fromRGB(40,25,85); rs.Thickness = 1; rs.Parent = row
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(0.56, 0, 1, 0); l.Position = UDim2.new(0, 10, 0, 0)
    l.BackgroundTransparency = 1; l.Text = lbl
    l.TextColor3 = Color3.fromRGB(140, 120, 200); l.Font = Enum.Font.Gotham
    l.TextScaled = true; l.TextXAlignment = Enum.TextXAlignment.Left; l.ZIndex = 21; l.Parent = row
    local badge = Instance.new("TextButton")
    badge.Size = UDim2.new(0.36, 0, 0.65, 0); badge.Position = UDim2.new(0.61, 0, 0.175, 0)
    badge.BackgroundColor3 = Color3.fromRGB(28, 16, 68)
    badge.TextColor3 = Color3.new(1, 1, 1); badge.Text = keybinds[key].Name
    badge.TextScaled = true; badge.Font = Enum.Font.GothamBold
    badge.BorderSizePixel = 0; badge.ZIndex = 22; badge.Parent = row
    Instance.new("UICorner", badge).CornerRadius = UDim.new(0, 7)
    local bs = Instance.new("UIStroke", badge); bs.Color = Color3.fromRGB(70,45,145); bs.Thickness = 1
    badge.MouseButton1Click:Connect(function()
        if listening then return end
        listening = key; badge.Text = "..."
        badge.TextColor3 = Color3.fromRGB(255, 215, 60)
        bs.Color = Color3.fromRGB(255, 200, 40)
    end)
    keyRefs[key] = { badge = badge, stroke = bs }
end

