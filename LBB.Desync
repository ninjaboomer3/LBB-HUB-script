local function mkBtn(txt, col, sc, y)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, W - 40, 0, BS)
    bg.Position = UDim2.new(0.5, -(W-40)/2, 0, y)
    bg.BackgroundColor3 = col
    bg.BorderSizePixel = 0
    bg.ZIndex = 20
    bg.Parent = main
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 12)
    local sk = Instance.new("UIStroke")
    sk.Color = sc; sk.Thickness = 1.2; sk.Transparency = 0.2; sk.Parent = bg
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = txt
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamBold
    btn.ZIndex = 21
    btn.Parent = bg
    return bg, btn, sk
end

