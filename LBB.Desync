local desynced, listeningFor = false, nil
local _pause, _resume, supported = nil, nil, false

-- Cleanup old
local pg = player:WaitForChild("PlayerGui")
local old = pg:FindFirstChild("LBBDesync")
if old then old:Destroy() end

