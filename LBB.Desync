--==================================================
-- FLOATING STAR PARTICLES
--==================================================
local starSizes = {3, 2, 2, 3, 2, 3, 2, 2, 3, 2, 2, 2, 3, 2, 2, 2, 2, 3, 2, 2}
local starAlphas = {0.9, 0.6, 0.8, 0.7, 0.9, 0.5, 0.8, 0.6, 0.9, 0.7, 0.6, 0.8, 0.9, 0.5, 0.7, 0.8, 0.6, 0.9, 0.7, 0.5}
local stars = {}

for i = 1, 20 do
    local star = Instance.new("Frame")
    local s = starSizes[i]
    star.Size = UDim2.new(0, s, 0, s)
    star.Position = UDim2.new(math.random(0, 100) / 100, 0, math.random(0, 100) / 100, 0)
    star.BackgroundColor3 = Color3.new(1, 1, 1)
    star.BackgroundTransparency = 1 - starAlphas[i]
    star.BorderSizePixel = 0
    star.ZIndex = 2
    star.Parent = main
    Instance.new("UICorner", star).CornerRadius = UDim.new(1, 0)
    table.insert(stars, star)
end

-- Animate stars (twinkle + slow drift)
for i, star in ipairs(stars) do
    local baseAlpha = 1 - starAlphas[i]
    local function twinkle()
        while true do
            local t = TweenService:Create(star,
                TweenInfo.new(math.random(15, 35) / 10, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {BackgroundTransparency = math.min(baseAlpha + 0.5, 0.98)}
            )
            t:Play(); t.Completed:Wait()
            local t2 = TweenService:Create(star,
                TweenInfo.new(math.random(15, 35) / 10, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {BackgroundTransparency = baseAlpha}
            )
            t2:Play(); t2.Completed:Wait()
        end
    end
    task.delay(i * 0.15, function() task.spawn(twinkle) end)
end

-- A few larger glowing orbs drifting slowly
for i = 1, 4 do
    local orb = Instance.new("Frame")
    orb.Size = UDim2.new(0, math.random(4, 7), 0, math.random(4, 7))
    orb.Position = UDim2.new(math.random(10, 90) / 100, 0, math.random(10, 90) / 100, 0)
    local colors = {
        Color3.fromRGB(160, 100, 255),
        Color3.fromRGB(80, 160, 255),
        Color3.fromRGB(200, 130, 255),
        Color3.fromRGB(100, 200, 255),
    }
    orb.BackgroundColor3 = colors[i]
    orb.BackgroundTransparency = 0.3
    orb.BorderSizePixel = 0
    orb.ZIndex = 2
    orb.Parent = main
    Instance.new("UICorner", orb).CornerRadius = UDim.new(1, 0)

    local function drift()
        while true do
            local newX = math.random(5, 95) / 100
            local newY = math.random(5, 95) / 100
            local t = TweenService:Create(orb,
                TweenInfo.new(math.random(60, 120) / 10, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {Position = UDim2.new(newX, 0, newY, 0)}
            )
            t:Play(); t.Completed:Wait()
        end
    end
    task.delay(i * 0.5, function() task.spawn(drift) end)
end

