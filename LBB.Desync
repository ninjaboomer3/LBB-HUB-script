divider.ZIndex           = 20
divider.Parent           = main

--==================================================
-- STATUS ROW (ZIndex 20)
--==================================================
local statusDot = Instance.new("Frame")
statusDot.Size             = UDim2.new(0, 10, 0, 10)
statusDot.Position         = UDim2.new(0.5, -60, 0, 76)
statusDot.BackgroundColor3 = Color3.fromRGB(80, 220, 120)
statusDot.BorderSizePixel  = 0
statusDot.ZIndex           = 20
statusDot.Parent           = main
Instance.new("UICorner", statusDot).CornerRadius = UDim.new(1, 0)

local statusLbl = Instance.new("TextLabel")
statusLbl.Size             = UDim2.new(0, 100, 0, 18)
statusLbl.Position         = UDim2.new(0.5, -46, 0, 72)
statusLbl.BackgroundTransparency = 1
statusLbl.Text             = "INACTIVE"
statusLbl.TextColor3       = Color3.fromRGB(80, 220, 120)
statusLbl.TextScaled       = true
statusLbl.Font             = Enum.Font.GothamBold
statusLbl.TextXAlignment   = Enum.TextXAlignment.Left
statusLbl.ZIndex           = 20
statusLbl.Parent           = main

--==================================================
-- TOGGLE BUTTON (ZIndex 20)
--==================================================
local btnBg = Instance.new("Frame")
btnBg.Size             = UDim2.new(0, 220, 0, 52)
btnBg.Position         = UDim2.new(0.5, -110, 0, 102)
btnBg.BackgroundColor3 = supported
    and Color3.fromRGB(55, 25, 130)
    or  Color3.fromRGB(40, 40, 40)
btnBg.BorderSizePixel  = 0
btnBg.ZIndex           = 20
btnBg.Parent           = main
Instance.new("UICorner", btnBg).CornerRadius = UDim.new(0, 13)

local btnStroke = Instance.new("UIStroke")
btnStroke.Color       = supported
    and Color3.fromRGB(120, 70, 255)
    or  Color3.fromRGB(80, 80, 80)
