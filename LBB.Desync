-- button factory
local function mkBtn(txt, col, sc, y)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 220, 0, 46)
    bg.Position = UDim2.new(0.5, -110, 0, y)
    bg.BackgroundColor3 = col
    bg.BorderSizePixel = 0
    bg.ZIndex = 20
    bg.Parent = main
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 12)
    local sk = Instance.new("UIStroke")
    sk.Color = sc; sk.Thickness = 1.2; sk.Transparency = 0.2; sk.Parent = bg
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = txt
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamBold
    btn.ZIndex = 21
    btn.Parent = bg
    return bg, btn, sk
end

local togBg, togBtn, togSk = mkBtn("ACTIVATE DESYNC", Color3.fromRGB(55,25,130), Color3.fromRGB(120,70,255), 96)
local tpBg,  tpBtn,  tpSk  = mkBtn("⚡ TELEPORT  [T]",  Color3.fromRGB(10,45,80),  Color3.fromRGB(50,160,255), 150)
tpBtn.TextColor3 = Color3.fromRGB(100, 200, 255)

-- keybind rows
local keyRefs = {}
local function mkRow(lbl, key, y)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(0, 220, 0, 32)
    row.Position = UDim2.new(0.5, -110, 0, y)
    row.BackgroundColor3 = Color3.fromRGB(10, 7, 28)
    row.BorderSizePixel = 0; row.ZIndex = 20; row.Parent = main
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 9)
    local rs = Instance.new("UIStroke"); rs.Color = Color3.fromRGB(40,25,85); rs.Thickness = 1; rs.Parent = row

    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(0.56, 0, 1, 0); l.Position = UDim2.new(0, 10, 0, 0)
    l.BackgroundTransparency = 1; l.Text = lbl
    l.TextColor3 = Color3.fromRGB(140, 120, 200); l.Font = Enum.Font.Gotham
    l.TextScaled = true; l.TextXAlignment = Enum.TextXAlignment.Left; l.ZIndex = 21; l.Parent = row

    local badge = Instance.new("TextButton")
    badge.Size = UDim2.new(0.36, 0, 0.65, 0); badge.Position = UDim2.new(0.61, 0, 0.175, 0)
    badge.BackgroundColor3 = Color3.fromRGB(28, 16, 68)
    badge.TextColor3 = Color3.new(1, 1, 1); badge.Text = keybinds[key].Name
    badge.TextScaled = true; badge.Font = Enum.Font.GothamBold
    badge.BorderSizePixel = 0; badge.ZIndex = 22; badge.Parent = row
    Instance.new("UICorner", badge).CornerRadius = UDim.new(0, 7)
    local bs = Instance.new("UIStroke", badge); bs.Color = Color3.fromRGB(70,45,145); bs.Thickness = 1

    badge.MouseButton1Click:Connect(function()
        if listening then return end
        listening = key; badge.Text = "..."
        badge.TextColor3 = Color3.fromRGB(255, 215, 60)
        bs.Color = Color3.fromRGB(255, 200, 40)
    end)
    keyRefs[key] = { badge = badge, stroke = bs }
end

mkRow("TOGGLE DESYNC", "toggle",   210)
mkRow("TELEPORT",      "teleport", 248)
mkRow("HIDE PANEL",    "panel",    286)

-- credit
local cr = Instance.new("TextLabel")
cr.Size = UDim2.new(1, 0, 0, 12); cr.Position = UDim2.new(0, 0, 1, -14)
cr.BackgroundTransparency = 1; cr.Text = "LBB · GALAXY EDITION"
cr.TextColor3 = Color3.fromRGB(35, 25, 70); cr.TextScaled = true
cr.Font = Enum.Font.Gotham; cr.ZIndex = 20; cr.Parent = main

--// UPDATE UI
local function updateUI()
    if desynced then
        dot.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
        slbl.Text = "ACTIVE"; slbl.TextColor3 = Color3.fromRGB(255, 70, 70)
        togBtn.Text = "DEACTIVATE DESYNC"
        togBg.BackgroundColor3 = Color3.fromRGB(110, 15, 35); togSk.Color = Color3.fromRGB(255, 60, 80)
        border.Color = Color3.fromRGB(220, 40, 70); glowP.ImageColor3 = Color3.fromRGB(180, 20, 50)
    else
        dot.BackgroundColor3 = Color3.fromRGB(80, 220, 120)
        slbl.Text = "INACTIVE"; slbl.TextColor3 = Color3.fromRGB(80, 220, 120)
        border.Color = Color3.fromRGB(90, 50, 200); glowP.ImageColor3 = Color3.fromRGB(100, 40, 220)
        if supported then
            togBtn.Text = "ACTIVATE DESYNC"; togBtn.TextColor3 = Color3.new(1, 1, 1)
            togBg.BackgroundColor3 = Color3.fromRGB(55, 25, 130); togSk.Color = Color3.fromRGB(120, 70, 255)
            sub.Text = "RAKNET · READY ✅"; sub.TextColor3 = Color3.fromRGB(100, 75, 210)
        else
            togBtn.Text = "RAKNET NOT FOUND"; togBtn.TextColor3 = Color3.fromRGB(140, 140, 140)
            togBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40); togSk.Color = Color3.fromRGB(80, 80, 80)
            sub.Text = "RAKNET · NOT FOUND ❌"; sub.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
    end
end

--// RAKNET DETECTION — fully protected, runs after UI is visible
task.spawn(function()
    task.wait(0.2)
    pcall(function()
        local envs = {}
        pcall(function() envs[#envs+1] = getgenv() end)
        pcall(function() envs[#envs+1] = getrenv() end)
        pcall(function() envs[#envs+1] = _G end)

        for _, env in ipairs(envs) do
            pcall(function()
                local rn = env.raknet
                if type(rn) ~= "table" then return end
                if type(rn.desync) == "function" then
                    _pause  = function() rn.desync(true)  end
                    _resume = function()
                        rn.desync(false)
                        task.wait()
                        rn.desync()
                    end
                elseif type(rn.desync) == "table" then
                    _pause  = rn.desync.pause  or rn.desync.enable
                    _resume = rn.desync.resume or rn.desync.disable
                elseif type(rn.pause) == "function" then
                    _pause = rn.pause; _resume = rn.resume
                end
            end)
            if _pause then break end
        end

        if not _pause then
            pcall(function()
                if type(raknetpause) == "function" then
                    _pause = raknetpause; _resume = raknetresume
                end
            end)
        end

        supported = type(_pause) == "function" and type(_resume) == "function"
        print("[LBB] RakNet supported: " .. tostring(supported))
        updateUI()
    end)
end)

--// CORE
local function pauseNet()
    if desynced or not supported then return end
    pcall(_pause); desynced = true; print("[LBB] DESYNCED")
end
local function resumeNet()
    if not desynced then return end
    pcall(_resume); desynced = false; print("[LBB] RESYNCED")
end
local function teleport()
    if not supported then return end
    if desynced then pcall(_resume) end
    task.wait()
    pcall(_pause); desynced = true
    print("[LBB] TELEPORTED — server updated, re-paused")
    updateUI()
end

player.CharacterAdded:Connect(function()
    if desynced then pcall(function() if _resume then _resume() end end); desynced = false end
    task.wait(0.1); updateUI()
end)

--// HEARTBEAT — only this block changed from original
RunService.Heartbeat:Connect(function(dt)
    if not desynced then return end
    local c = player.Character; if not c then return end
    local h = c:FindFirstChildOfClass("Humanoid")
    if h and h.Health <= 0 then resumeNet(); updateUI() end

    -- interaction pulse with position restore
    if not pulseEnabled or not supported or pulsing then return end
    pulseTimer += dt
    if pulseTimer < PULSE_INTERVAL then return end
    pulseTimer = 0
    pulsing = true
    task.spawn(function()
        local root = c and c:FindFirstChild("HumanoidRootPart")
        local savedCF = root and root.CFrame
        pcall(_resume)
        task.wait(PULSE_DURATION)
        pcall(_pause)
        if root and savedCF then
            root.CFrame = savedCF
        end
        pulsing = false
    end)
end)

--// BUTTON BOUNCE
local function bounce(bg)
    local s, p = bg.Size, bg.Position
    TweenService:Create(bg, TweenInfo.new(0.07, Enum.EasingStyle.Quad), {
        Size = UDim2.new(0, s.X.Offset-8, 0, s.Y.Offset-4),
        Position = UDim2.new(p.X.Scale, p.X.Offset+4, p.Y.Scale, p.Y.Offset+2)
    }):Play()
    task.delay(0.07, function()
        TweenService:Create(bg, TweenInfo.new(0.14, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size=s, Position=p}):Play()
    end)
end

togBtn.MouseButton1Click:Connect(function()
    if not supported then warn("[LBB] RakNet not found"); return end
    bounce(togBg)
    if desynced then resumeNet() else pauseNet() end
    updateUI()
end)
tpBtn.MouseButton1Click:Connect(function()
    bounce(tpBg); teleport()
end)

--// DRAG
local drag, ds, sp
header.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        drag = true; ds = i.Position; sp = main.Position
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
        local d = i.Position - ds
        main.Position = UDim2.new(sp.X.Scale, sp.X.Offset+d.X, sp.Y.Scale, sp.Y.Offset+d.Y)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
end)

--// KEYBINDS
UserInputService.InputBegan:Connect(function(input, gp)
    if listening then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            keybinds[listening] = input.KeyCode
            local r = keyRefs[listening]
            if r then
                r.badge.Text = input.KeyCode.Name
                r.badge.TextColor3 = Color3.new(1, 1, 1)
                r.stroke.Color = Color3.fromRGB(70, 45, 145)
            end
            listening = nil
        end
        return
    end
    if gp then return end
    if input.KeyCode == keybinds.toggle then
        if not supported then return end
        if desynced then resumeNet() else pauseNet() end; updateUI()
    elseif input.KeyCode == keybinds.teleport then
        teleport()
    elseif input.KeyCode == keybinds.panel then
        gui.Enabled = not gui.Enabled
    end
end)

print("🌌 LBB Desync loaded | H=toggle | T=teleport | U=hide")
