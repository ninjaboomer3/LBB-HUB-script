--// UPDATE UI
local function updateUI()
    if desynced then
        dot.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
        slbl.Text = "ACTIVE"; slbl.TextColor3 = Color3.fromRGB(255, 70, 70)
        togBtn.Text = "DEACTIVATE DESYNC"
        togBg.BackgroundColor3 = Color3.fromRGB(110, 15, 35); togSk.Color = Color3.fromRGB(255, 60, 80)
        border.Color = Color3.fromRGB(220, 40, 70); glowP.ImageColor3 = Color3.fromRGB(180, 20, 50)
        if isMobile and stealBg then
            stealBg.BackgroundColor3 = Color3.fromRGB(20, 70, 30)
            stealBtn.TextColor3 = Color3.fromRGB(100, 255, 130)
        end
    else
        dot.BackgroundColor3 = Color3.fromRGB(80, 220, 120)
        slbl.Text = "INACTIVE"; slbl.TextColor3 = Color3.fromRGB(80, 220, 120)
        border.Color = Color3.fromRGB(90, 50, 200); glowP.ImageColor3 = Color3.fromRGB(100, 40, 220)
        if isMobile and stealBg then
            stealBg.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
            stealBtn.TextColor3 = Color3.fromRGB(100, 100, 120)
        end
        if supported then
            togBtn.Text = "ACTIVATE DESYNC"; togBtn.TextColor3 = Color3.new(1, 1, 1)
            togBg.BackgroundColor3 = Color3.fromRGB(55, 25, 130); togSk.Color = Color3.fromRGB(120, 70, 255)
            sub.Text = "RAKNET · READY ✅"; sub.TextColor3 = Color3.fromRGB(100, 75, 210)
        else
            togBtn.Text = "RAKNET NOT FOUND"; togBtn.TextColor3 = Color3.fromRGB(140, 140, 140)
            togBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40); togSk.Color = Color3.fromRGB(80, 80, 80)
            sub.Text = "RAKNET · NOT FOUND ❌"; sub.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
    end
end

--// RAKNET DETECTION — fully protected, runs after UI is visible
task.spawn(function()
    task.wait(0.2)
    pcall(function()
        local envs = {}
        pcall(function() envs[#envs+1] = getgenv() end)
        pcall(function() envs[#envs+1] = getrenv() end)
        pcall(function() envs[#envs+1] = _G end)
        for _, env in ipairs(envs) do
            pcall(function()
                local rn = env.raknet
                if type(rn) ~= "table" then return end
                if type(rn.desync) == "function" then
                    _pause  = function() rn.desync(true)  end
                    _resume = function()
                        rn.desync(false)
                        task.wait()
                        rn.desync()
                    end
                elseif type(rn.desync) == "table" then
                    _pause  = rn.desync.pause  or rn.desync.enable
                    _resume = rn.desync.resume or rn.desync.disable
                elseif type(rn.pause) == "function" then
                    _pause = rn.pause; _resume = rn.resume
                end
            end)
            if _pause then break end
        end
        if not _pause then
            pcall(function()
                if type(raknetpause) == "function" then
                    _pause = raknetpause; _resume = raknetresume
                end
            end)
        end
        supported = type(_pause) == "function" and type(_resume) == "function"
        print("[LBB] RakNet supported: " .. tostring(supported))
        updateUI()
    end)
end)

--// CORE
local function pauseNet()
    if desynced or not supported then return end
    pcall(_pause); desynced = true; print("[LBB] DESYNCED")
end
local function resumeNet()
    if not desynced then return end
    pcall(_resume); desynced = false; print("[LBB] RESYNCED")
end
local function teleport()
    if not supported then return end
    if desynced then pcall(_resume) end
    task.wait()
    pcall(_pause); desynced = true
    print("[LBB] TELEPORTED — server updated, re-paused")
    updateUI()
end

player.CharacterAdded:Connect(function()
    if desynced then pcall(function() if _resume then _resume() end end); desynced = false end
    task.wait(0.1); updateUI()
end)

--// HEARTBEAT
RunService.Heartbeat:Connect(function(dt)
    if not desynced then return end
    local c = player.Character; if not c then return end
    local h = c:FindFirstChildOfClass("Humanoid")
    if h and h.Health <= 0 then resumeNet(); updateUI() end
end)

--// BUTTON BOUNCE
local function bounce(bg)
    local s, p = bg.Size, bg.Position
    TweenService:Create(bg, TweenInfo.new(0.07, Enum.EasingStyle.Quad), {
        Size = UDim2.new(0, s.X.Offset-8, 0, s.Y.Offset-4),
        Position = UDim2.new(p.X.Scale, p.X.Offset+4, p.Y.Scale, p.Y.Offset+2)
    }):Play()
    task.delay(0.07, function()
        TweenService:Create(bg, TweenInfo.new(0.14, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size=s, Position=p}):Play()
    end)
end

togBtn.MouseButton1Click:Connect(function()
    if not supported then warn("[LBB] RakNet not found"); return end
    bounce(togBg)
    if desynced then resumeNet() else pauseNet() end
    updateUI()
end)
tpBtn.MouseButton1Click:Connect(function()
    bounce(tpBg); teleport()
end)

--// DRAG — touch + mouse
local drag, ds, sp
header.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1
    or i.UserInputType == Enum.UserInputType.Touch then
        drag = true; ds = i.Position; sp = main.Position
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if drag and (i.UserInputType == Enum.UserInputType.MouseMovement
    or i.UserInputType == Enum.UserInputType.Touch) then
        local d = i.Position - ds
        main.Position = UDim2.new(sp.X.Scale, sp.X.Offset+d.X, sp.Y.Scale, sp.Y.Offset+d.Y)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1
    or i.UserInputType == Enum.UserInputType.Touch then drag = false end
end)

--// KEYBINDS — PC only
UserInputService.InputBegan:Connect(function(input, gp)
    if listening then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            keybinds[listening] = input.KeyCode
            local r = keyRefs[listening]
            if r then
                r.badge.Text = input.KeyCode.Name
                r.badge.TextColor3 = Color3.new(1, 1, 1)
                r.stroke.Color = Color3.fromRGB(70, 45, 145)
            end
            listening = nil
        end
        return
    end
    if gp then return end
    if not isMobile then
        if input.KeyCode == keybinds.toggle then
            if not supported then return end
            if desynced then resumeNet() else pauseNet() end; updateUI()
        elseif input.KeyCode == keybinds.teleport then
            teleport()
        elseif input.KeyCode == keybinds.panel then
            gui.Enabled = not gui.Enabled
        elseif input.KeyCode == Enum.KeyCode.E and desynced then
            fireNearest()
        end
    end
end)

print("🌌 LBB Desync loaded | platform: " .. (isMobile and "MOBILE" or "PC"))
