-- Galaxy BG ZIndex 2
local function makeGlow(col,sz,x,y,tr)
    local g=Instance.new("ImageLabel")
    g.Size=UDim2.new(0,sz,0,sz); g.Position=UDim2.new(0,x,0,y)
    g.BackgroundTransparency=1; g.Image="rbxassetid://5554236805"
    g.ImageColor3=col; g.ImageTransparency=tr
    g.ScaleType=Enum.ScaleType.Slice; g.SliceCenter=Rect.new(23,23,277,277)
    g.ZIndex=2; g.Parent=main; return g
end
local glowPurple=makeGlow(Color3.fromRGB(100,40,220),220,60,-70,0.42)
local glowBlue  =makeGlow(Color3.fromRGB(20,80,210),190,-55,180,0.48)

for i=1,22 do
    local s=Instance.new("Frame")
    s.Size=UDim2.new(0,(i%3==0)and 3 or 2,0,(i%3==0)and 3 or 2)
    s.Position=UDim2.new(math.random(2,96)/100,0,math.random(2,96)/100,0)
    s.BackgroundColor3=Color3.new(1,1,1)
    local bt=math.random(1,4)/10+0.1; s.BackgroundTransparency=bt
    s.BorderSizePixel=0; s.ZIndex=2; s.Parent=main
    Instance.new("UICorner",s).CornerRadius=UDim.new(1,0)
    local sf,base=s,bt
    task.delay(i*0.11,function()
        while true do
            TweenService:Create(sf,TweenInfo.new(math.random(12,30)/10,Enum.EasingStyle.Sine),{BackgroundTransparency=math.min(base+0.55,0.96)}):Play()
            task.wait(math.random(12,30)/10)
            TweenService:Create(sf,TweenInfo.new(math.random(12,30)/10,Enum.EasingStyle.Sine),{BackgroundTransparency=base}):Play()
            task.wait(math.random(12,30)/10)
        end
    end)
end
for i,col in ipairs({Color3.fromRGB(140,80,255),Color3.fromRGB(60,140,255),Color3.fromRGB(200,100,255),Color3.fromRGB(80,200,255)}) do
    local orb=Instance.new("Frame")
    orb.Size=UDim2.new(0,math.random(4,7),0,math.random(4,7))
    orb.Position=UDim2.new(math.random(10,90)/100,0,math.random(10,90)/100,0)
    orb.BackgroundColor3=col; orb.BackgroundTransparency=0.25
    orb.BorderSizePixel=0; orb.ZIndex=2; orb.Parent=main
    Instance.new("UICorner",orb).CornerRadius=UDim.new(1,0)
    local of=orb
    task.delay(i*0.4,function()
        while true do
            TweenService:Create(of,TweenInfo.new(math.random(50,110)/10,Enum.EasingStyle.Sine),{Position=UDim2.new(math.random(5,90)/100,0,math.random(5,90)/100,0)}):Play()
            task.wait(math.random(50,110)/10)
        end
    end)
end

