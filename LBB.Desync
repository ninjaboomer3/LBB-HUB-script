--==================================================
-- GALAXY ATMOSPHERE (low ZIndex, behind everything)
--==================================================
local function makeGlow(color, size, posX, posY, transparency)
    local g = Instance.new("ImageLabel")
    g.Size = UDim2.new(0, size, 0, size)
    g.Position = UDim2.new(0, posX, 0, posY)
    g.BackgroundTransparency = 1
    g.Image = "rbxassetid://5554236805"
    g.ImageColor3 = color
    g.ImageTransparency = transparency
    g.ScaleType = Enum.ScaleType.Slice
    g.SliceCenter = Rect.new(23, 23, 277, 277)
    g.ZIndex = 1
    g.Parent = main
    return g
end

local glowPurple = makeGlow(Color3.fromRGB(100, 40, 220), 200, 80, -60, 0.45)
local glowBlue   = makeGlow(Color3.fromRGB(20, 80, 210),  180, -50, 160, 0.5)

-- Twinkling stars
local starData = {}
for i = 1, 22 do
    local s = Instance.new("Frame")
    local sz = (i % 3 == 0) and 3 or 2
    s.Size = UDim2.new(0, sz, 0, sz)
    s.Position = UDim2.new(math.random(2, 96)/100, 0, math.random(2, 96)/100, 0)
    s.BackgroundColor3 = Color3.new(1, 1, 1)
    s.BackgroundTransparency = math.random(1, 5) / 10 + 0.1
    s.BorderSizePixel = 0
    s.ZIndex = 2
    s.Parent = main
    Instance.new("UICorner", s).CornerRadius = UDim.new(1, 0)
    table.insert(starData, {frame = s, base = s.BackgroundTransparency})
end

for i, sd in ipairs(starData) do
    task.delay(i * 0.12, function()
        while true do
            TweenService:Create(sd.frame,
                TweenInfo.new(math.random(12, 30)/10, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {BackgroundTransparency = math.min(sd.base + 0.55, 0.97)}
            ):Play()
            task.wait(math.random(12, 30)/10)
            TweenService:Create(sd.frame,
                TweenInfo.new(math.random(12, 30)/10, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {BackgroundTransparency = sd.base}
            ):Play()
            task.wait(math.random(12, 30)/10)
        end
    end)
end

-- Drifting orbs
local orbColors = {
    Color3.fromRGB(140, 80, 255),
    Color3.fromRGB(60, 140, 255),
    Color3.fromRGB(200, 100, 255),
    Color3.fromRGB(80, 200, 255),
}
for i = 1, 4 do
    local orb = Instance.new("Frame")
    orb.Size = UDim2.new(0, math.random(4,7), 0, math.random(4,7))
    orb.Position = UDim2.new(math.random(10,90)/100, 0, math.random(10,90)/100, 0)
    orb.BackgroundColor3 = orbColors[i]
    orb.BackgroundTransparency = 0.25
    orb.BorderSizePixel = 0
    orb.ZIndex = 2
    orb.Parent = main
    Instance.new("UICorner", orb).CornerRadius = UDim.new(1, 0)
    task.delay(i * 0.4, function()
        while true do
            TweenService:Create(orb,
                TweenInfo.new(math.random(50,110)/10, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {Position = UDim2.new(math.random(5,90)/100, 0, math.random(5,90)/100, 0)}
            ):Play()
            task.wait(math.random(50,110)/10)
        end
    end)
end

--==================================================
-- HELPER: make a UI element always above particles
--==================================================
local function label(text, sizeY, posY, font, color, bold)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1, -20, 0, sizeY)
    l.Position = UDim2.new(0, 10, 0, posY)
    l.BackgroundTransparency = 1
    l.Text = text
    l.TextColor3 = color or Color3.new(1,1,1)
    l.TextScaled = true
    l.Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham
    l.ZIndex = 5
    l.Parent = main
    return l
end

