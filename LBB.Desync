--==================================================
-- KEYBIND ROWS (ZIndex 20)
--==================================================
local keyBtnRefs = {}

local function makeKeybindRow(labelText, bindKey, posY)
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(0, 210, 0, 36)
    row.Position         = UDim2.new(0.5, -105, 0, posY)
    row.BackgroundColor3 = Color3.fromRGB(11, 7, 32)
    row.BorderSizePixel  = 0
    row.ZIndex           = 20
    row.Parent           = main
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 10)

    local rowStroke = Instance.new("UIStroke")
    rowStroke.Color       = Color3.fromRGB(45, 28, 95)
    rowStroke.Thickness   = 1
    rowStroke.Parent      = row

    local lbl = Instance.new("TextLabel")
    lbl.Size             = UDim2.new(0.55, 0, 1, 0)
    lbl.Position         = UDim2.new(0, 12, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text             = labelText
    lbl.TextColor3       = Color3.fromRGB(150, 130, 205)
    lbl.Font             = Enum.Font.Gotham
    lbl.TextScaled       = true
    lbl.TextXAlignment   = Enum.TextXAlignment.Left
    lbl.ZIndex           = 21
    lbl.Parent           = row

    local badge = Instance.new("TextButton")
    badge.Size             = UDim2.new(0.37, 0, 0.68, 0)
    badge.Position         = UDim2.new(0.6, 0, 0.16, 0)
    badge.BackgroundColor3 = Color3.fromRGB(30, 18, 75)
    badge.TextColor3       = Color3.new(1,1,1)
    badge.Text             = keybinds[bindKey].Name
    badge.TextScaled       = true
    badge.Font             = Enum.Font.GothamBold
    badge.BorderSizePixel  = 0
    badge.ZIndex           = 22
    badge.Parent           = row
    Instance.new("UICorner", badge).CornerRadius = UDim.new(0, 7)

    local badgeStroke = Instance.new("UIStroke")
    badgeStroke.Color     = Color3.fromRGB(75, 48, 155)
    badgeStroke.Thickness = 1
    badgeStroke.Parent    = badge

    badge.MouseButton1Click:Connect(function()
        if listeningFor then return end
        listeningFor = bindKey
        badge.Text      = "..."
        badge.TextColor3 = Color3.fromRGB(255, 215, 60)
        badgeStroke.Color = Color3.fromRGB(255, 200, 40)
    end)

    keyBtnRefs[bindKey] = {badge = badge, stroke = badgeStroke}
end

makeKeybindRow("TOGGLE DESYNC", "toggle", 170)
makeKeybindRow("HIDE PANEL",    "panel",  215)

