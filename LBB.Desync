--==================================================
-- KEYBIND ROWS
--==================================================
local function makeKeybindRow(labelText, bindKey, posY)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(0, 210, 0, 36)
    row.Position = UDim2.new(0.5, -105, 0, posY)
    row.BackgroundColor3 = Color3.fromRGB(12, 8, 35)
    row.BorderSizePixel = 0
    row.ZIndex = 5
    row.Parent = main
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 10)

    local rowStroke = Instance.new("UIStroke")
    rowStroke.Color = Color3.fromRGB(50, 30, 100)
    rowStroke.Thickness = 1
    rowStroke.Transparency = 0.3
    rowStroke.Parent = row

    local rowLabel = Instance.new("TextLabel")
    rowLabel.Size = UDim2.new(0.55, 0, 1, 0)
    rowLabel.Position = UDim2.new(0, 12, 0, 0)
    rowLabel.BackgroundTransparency = 1
    rowLabel.Text = labelText
    rowLabel.TextColor3 = Color3.fromRGB(160, 140, 210)
    rowLabel.Font = Enum.Font.Gotham
    rowLabel.TextScaled = true
    rowLabel.TextXAlignment = Enum.TextXAlignment.Left
    rowLabel.ZIndex = 6
    rowLabel.Parent = row

    local keyBtn = Instance.new("TextButton")
    keyBtn.Size = UDim2.new(0.38, 0, 0.7, 0)
    keyBtn.Position = UDim2.new(0.59, 0, 0.15, 0)
    keyBtn.BackgroundColor3 = Color3.fromRGB(35, 20, 80)
    keyBtn.TextColor3 = Color3.new(1, 1, 1)
    keyBtn.Text = keybinds[bindKey].Name
    keyBtn.TextScaled = true
    keyBtn.Font = Enum.Font.GothamBold
    keyBtn.BorderSizePixel = 0
    keyBtn.ZIndex = 7
    keyBtn.Parent = row
    Instance.new("UICorner", keyBtn).CornerRadius = UDim.new(0, 7)

    local keyStroke = Instance.new("UIStroke")
    keyStroke.Color = Color3.fromRGB(80, 50, 160)
    keyStroke.Thickness = 1
    keyStroke.Parent = keyBtn

    keyBtn.MouseButton1Click:Connect(function()
        if listeningFor then return end
        listeningFor = bindKey
        keyBtn.Text = "..."
        keyBtn.TextColor3 = Color3.fromRGB(255, 220, 80)
        keyStroke.Color = Color3.fromRGB(255, 200, 50)
    end)

    return keyBtn
end

local toggleKeyBtn = makeKeybindRow("TOGGLE DESYNC", "toggle", 186)
local panelKeyBtn  = makeKeybindRow("HIDE PANEL",    "panel",  230)

-- Credit
local creditLbl = label("LBB · GALAXY EDITION", 14, 282, Enum.Font.Gotham, Color3.fromRGB(40, 30, 80), false)

--==================================================
-- UPDATE UI
--==================================================
function updateUI()
    if desynced then
        statusDot.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
        statusLbl.Text = "ACTIVE"
        statusLbl.TextColor3 = Color3.fromRGB(255, 70, 70)
        toggleBtn.Text = "DEACTIVATE DESYNC"
        btnBg.BackgroundColor3 = Color3.fromRGB(110, 15, 35)
        btnGlow.Color = Color3.fromRGB(255, 60, 80)
        border.Color = Color3.fromRGB(220, 40, 70)
        glowPurple.ImageColor3 = Color3.fromRGB(180, 20, 50)
    else
        statusDot.BackgroundColor3 = Color3.fromRGB(80, 220, 120)
        statusLbl.Text = "INACTIVE"
        statusLbl.TextColor3 = Color3.fromRGB(80, 220, 120)
        toggleBtn.Text = "ACTIVATE DESYNC"
        btnBg.BackgroundColor3 = Color3.fromRGB(55, 25, 130)
        btnGlow.Color = Color3.fromRGB(120, 70, 255)
        border.Color = Color3.fromRGB(90, 50, 200)
        glowPurple.ImageColor3 = Color3.fromRGB(100, 40, 220)
    end
end

updateUI()

--==================================================
-- BUTTON CLICK WITH BOUNCE
--==================================================
toggleBtn.MouseButton1Click:Connect(function()
    TweenService:Create(btnBg,
        TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {Size = UDim2.new(0, 202, 0, 46), Position = UDim2.new(0.5, -101, 0, 124)}
    ):Play()
    task.delay(0.08, function()
        TweenService:Create(btnBg,
            TweenInfo.new(0.14, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
            {Size = UDim2.new(0, 210, 0, 50), Position = UDim2.new(0.5, -105, 0, 122)}
        ):Play()
    end)
    if desynced then resumeNet() else pauseNet() end
    updateUI()
end)

--==================================================
-- KEYBIND LISTENER
--==================================================
UserInputService.InputBegan:Connect(function(input, gp)
    -- Rebind mode
    if listeningFor then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            keybinds[listeningFor] = input.KeyCode
            local btn = listeningFor == "toggle" and toggleKeyBtn or panelKeyBtn
            btn.Text = input.KeyCode.Name
            btn.TextColor3 = Color3.new(1, 1, 1)
            -- reset stroke color
            for _, v in ipairs(btn:GetChildren()) do
                if v:IsA("UIStroke") then v.Color = Color3.fromRGB(80, 50, 160) end
            end
            listeningFor = nil
        end
        return
    end

    if gp then return end

    if input.KeyCode == keybinds.toggle then
        if desynced then resumeNet() else pauseNet() end
        updateUI()
    elseif input.KeyCode == keybinds.panel then
        gui.Enabled = not gui.Enabled
    end
end)

--==================================================
-- DRAGGABLE
--==================================================
local dragging, dragStart, startPos
main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local d = input.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

--==================================================
-- SAFETY: auto resume on death
--==================================================
RunService.Heartbeat:Connect(function()
    if not desynced then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health <= 0 then resumeNet(); updateUI() end
end)

print("🌌 LBB Desync loaded.")
