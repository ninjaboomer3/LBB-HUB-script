toggleBtn.ZIndex           = 21
toggleBtn.Parent           = btnBg

--==================================================
-- KEYBIND ROWS (ZIndex 20)
--==================================================
local keyBtnRefs = {}

local function makeKeyRow(labelText, bindKey, posY)
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(0, 220, 0, 34)
    row.Position         = UDim2.new(0.5, -110, 0, posY)
    row.BackgroundColor3 = Color3.fromRGB(10, 7, 28)
    row.BorderSizePixel  = 0
    row.ZIndex           = 20
    row.Parent           = main
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 9)
    local rs = Instance.new("UIStroke")
    rs.Color = Color3.fromRGB(40, 25, 85)
    rs.Thickness = 1
    rs.Parent = row

    local lbl = Instance.new("TextLabel")
    lbl.Size             = UDim2.new(0.55, 0, 1, 0)
    lbl.Position         = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text             = labelText
    lbl.TextColor3       = Color3.fromRGB(140, 120, 200)
    lbl.Font             = Enum.Font.Gotham
    lbl.TextScaled       = true
    lbl.TextXAlignment   = Enum.TextXAlignment.Left
    lbl.ZIndex           = 21
    lbl.Parent           = row

    local badge = Instance.new("TextButton")
    badge.Size             = UDim2.new(0.37, 0, 0.68, 0)
    badge.Position         = UDim2.new(0.6, 0, 0.16, 0)
    badge.BackgroundColor3 = Color3.fromRGB(28, 16, 68)
    badge.TextColor3       = Color3.new(1, 1, 1)
    badge.Text             = keybinds[bindKey].Name
    badge.TextScaled       = true
    badge.Font             = Enum.Font.GothamBold
    badge.BorderSizePixel  = 0
    badge.ZIndex           = 22
    badge.Parent           = row
    Instance.new("UICorner", badge).CornerRadius = UDim.new(0, 7)

    local bs = Instance.new("UIStroke")
    bs.Color     = Color3.fromRGB(70, 45, 145)
    bs.Thickness = 1
    bs.Parent    = badge

    badge.MouseButton1Click:Connect(function()
        if listeningFor then return end
        listeningFor        = bindKey
        badge.Text          = "..."
        badge.TextColor3    = Color3.fromRGB(255, 215, 60)
        bs.Color            = Color3.fromRGB(255, 200, 40)
    end)

    keyBtnRefs[bindKey] = {badge = badge, stroke = bs}
end

makeKeyRow("TOGGLE DESYNC", "toggle", 172)
makeKeyRow("HIDE PANEL",    "panel",  214)

local creditLbl = Instance.new("TextLabel")
creditLbl.Size             = UDim2.new(1, 0, 0, 14)
creditLbl.Position         = UDim2.new(0, 0, 1, -20)
creditLbl.BackgroundTransparency = 1
creditLbl.Text             = "LBB · GALAXY EDITION"
creditLbl.TextColor3       = Color3.fromRGB(35, 25, 70)
creditLbl.TextScaled       = true
creditLbl.Font             = Enum.Font.Gotham
creditLbl.ZIndex           = 20
creditLbl.Parent           = main

--==================================================
-- UPDATE UI
--==================================================
function updateUI()
    if desynced then
        statusDot.BackgroundColor3  = Color3.fromRGB(255, 70, 70)
        statusLbl.Text              = "ACTIVE"
        statusLbl.TextColor3        = Color3.fromRGB(255, 70, 70)
        toggleBtn.Text              = "DEACTIVATE DESYNC"
        btnBg.BackgroundColor3      = Color3.fromRGB(110, 15, 35)
        btnStroke.Color             = Color3.fromRGB(255, 60, 80)
        mainBorder.Color            = Color3.fromRGB(220, 40, 70)
        glowPurple.ImageColor3      = Color3.fromRGB(180, 20, 50)
    else
        statusDot.BackgroundColor3  = Color3.fromRGB(80, 220, 120)
        statusLbl.Text              = "INACTIVE"
        statusLbl.TextColor3        = Color3.fromRGB(80, 220, 120)
        toggleBtn.Text              = supported and "ACTIVATE DESYNC" or "NO RAKNET SUPPORT"
        btnBg.BackgroundColor3      = supported and Color3.fromRGB(55, 25, 130) or Color3.fromRGB(40, 40, 40)
        btnStroke.Color             = supported and Color3.fromRGB(120, 70, 255) or Color3.fromRGB(80, 80, 80)
        mainBorder.Color            = Color3.fromRGB(90, 50, 200)
        glowPurple.ImageColor3      = Color3.fromRGB(100, 40, 220)
    end
end

updateUI()

--==================================================
-- BUTTON — bounce animation + toggle
--==================================================
toggleBtn.MouseButton1Click:Connect(function()
    if not supported then
        warn("[LBB] Can't desync — raknetpause not found in getgenv()")
        return
    end
    -- Press in
    TweenService:Create(btnBg, TweenInfo.new(0.07, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size     = UDim2.new(0, 212, 0, 48),
        Position = UDim2.new(0.5, -106, 0, 104),
    }):Play()
    task.delay(0.07, function()
        TweenService:Create(btnBg, TweenInfo.new(0.14, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size     = UDim2.new(0, 220, 0, 52),
            Position = UDim2.new(0.5, -110, 0, 102),
        }):Play()
    end)
    if desynced then resumeNet() else pauseNet() end
    updateUI()
end)

--==================================================
-- DRAGGABLE — header only so buttons stay clickable
--==================================================
local dragging, dragStart, startPos
header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging  = true
        dragStart = input.Position
        startPos  = main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local d = input.Position - dragStart
        main.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + d.X,
            startPos.Y.Scale, startPos.Y.Offset + d.Y
        )
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

--==================================================
-- KEYBINDS
--==================================================
UserInputService.InputBegan:Connect(function(input, gp)
    -- Rebind mode
    if listeningFor then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            keybinds[listeningFor]  = input.KeyCode
            local ref = keyBtnRefs[listeningFor]
            if ref then
                ref.badge.Text       = input.KeyCode.Name
                ref.badge.TextColor3 = Color3.new(1, 1, 1)
                ref.stroke.Color     = Color3.fromRGB(70, 45, 145)
            end
            listeningFor = nil
        end
        return
    end

    if gp then return end

    if input.KeyCode == keybinds.toggle then
        if not supported then
            warn("[LBB] raknetpause not available")
            return
        end
        if desynced then resumeNet() else pauseNet() end
        updateUI()
    elseif input.KeyCode == keybinds.panel then
        gui.Enabled = not gui.Enabled
    end
end)

--==================================================
-- SAFETY: auto resume on death
--==================================================
RunService.Heartbeat:Connect(function()
    if not desynced then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health <= 0 then
        resumeNet()
        updateUI()
    end
end)

print("🌌 LBB Desync loaded — RakNet " .. (supported and "✅ READY" or "❌ NOT FOUND"))
