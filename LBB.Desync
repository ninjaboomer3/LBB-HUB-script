local function mkSelBtn(txt, col, sc, x)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 100, 0, 52)
    bg.Position = UDim2.new(0, x, 0, 90)
    bg.BackgroundColor3 = col
    bg.BorderSizePixel = 0
    bg.ZIndex = 10
    bg.Parent = selBox
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 12)
    local sk = Instance.new("UIStroke", bg)
    sk.Color = sc; sk.Thickness = 1.2; sk.Transparency = 0.2
    local icon = Instance.new("TextLabel")
    icon.Size = UDim2.new(1, 0, 0, 24)
    icon.Position = UDim2.new(0, 0, 0, 4)
    icon.BackgroundTransparency = 1
    icon.TextScaled = true
    icon.ZIndex = 11
    icon.Font = Enum.Font.GothamBold
    icon.TextColor3 = Color3.new(1,1,1)
    icon.Parent = bg
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 0, 18)
    lbl.Position = UDim2.new(0, 0, 0, 28)
    lbl.BackgroundTransparency = 1
    lbl.TextScaled = true
    lbl.ZIndex = 11
    lbl.Font = Enum.Font.GothamBold
    lbl.TextColor3 = Color3.new(1,1,1)
    lbl.Parent = bg
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.ZIndex = 12
    btn.Parent = bg
    return bg, btn, icon, lbl, sk
end

