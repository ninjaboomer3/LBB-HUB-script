--==================================================
-- LBB DESYNC — GALAXY EDITION
-- RakNet desync: pauses ALL outgoing packets.
-- Server sees you frozen. Client moves freely.
-- On resume, server snaps to your real position.
--==================================================

local Players        = game:GetService("Players")
local RunService     = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService   = game:GetService("TweenService")

local player    = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

--==================================================
-- KEYBINDS (click the badge in-UI to rebind)
--==================================================
local keybinds = {
    toggle = Enum.KeyCode.H,
    panel  = Enum.KeyCode.U,
}

--==================================================
-- STATE
--==================================================
local desynced     = false
local listeningFor = nil  -- which keybind is being rebound

--==================================================
-- RAKNET CORE
-- raknetpause() stops ALL outgoing UDP packets.
-- Server physics sees you frozen at last sent pos.
-- raknetresume() resumes packets; server teleports
-- you to wherever your HRP actually is client-side.
--==================================================
local function pauseNet()
    if desynced then return end
    desynced = true
    pcall(function() raknetpause() end)
    print("[LBB] Desynced — server frozen")
end

local function resumeNet()
    if not desynced then return end
    desynced = false
    pcall(function() raknetresume() end)
    print("[LBB] Resynced — server updated")
end

player.CharacterAdded:Connect(function(c)
    character = c
    pcall(function() raknetresume() end)
    desynced = false
    if updateUI then updateUI() end
end)

--==================================================
-- GUI ROOT — default ZIndexBehavior (Global)
-- Global = ZIndex is an absolute value, higher always
-- renders on top regardless of parent hierarchy.
-- Particles = ZIndex 2, UI content = ZIndex 20+
--==================================================
local gui = Instance.new("ScreenGui")
gui.Name            = "LBBDesync"
gui.ResetOnSpawn    = false
gui.DisplayOrder    = 99999
gui.Enabled         = true
gui.Parent          = player:WaitForChild("PlayerGui")

-- Main window
local main = Instance.new("Frame")
main.Size            = UDim2.new(0, 260, 0, 315)
main.Position        = UDim2.new(0.5, -130, 0.5, -157)
main.BackgroundColor3 = Color3.fromRGB(6, 4, 20)
main.BorderSizePixel = 0
main.ZIndex          = 1
main.Parent          = gui
Instance.new("UICorner", main).CornerRadius = UDim.new(0, 18)

local mainBorder = Instance.new("UIStroke")
mainBorder.Color       = Color3.fromRGB(90, 50, 200)
mainBorder.Thickness   = 1.5
mainBorder.Transparency = 0.1
mainBorder.Parent      = main

--==================================================
-- GALAXY PARTICLES (ZIndex 2 — below all UI)
--==================================================
-- Soft glow blobs
local function glow(col, sz, x, y, trans)
    local g = Instance.new("ImageLabel")
    g.Size             = UDim2.new(0, sz, 0, sz)
    g.Position         = UDim2.new(0, x, 0, y)
    g.BackgroundTransparency = 1
    g.Image            = "rbxassetid://5554236805"
    g.ImageColor3      = col
    g.ImageTransparency = trans
    g.ScaleType        = Enum.ScaleType.Slice
    g.SliceCenter      = Rect.new(23,23,277,277)
    g.ZIndex           = 2
    g.Parent           = main
    return g
end

local glowPurple = glow(Color3.fromRGB(100,40,220), 220, 60, -70, 0.42)
local glowBlue   = glow(Color3.fromRGB(20,80,210),  190, -55, 170, 0.48)

-- Stars
local starList = {}
for i = 1, 22 do
    local s  = Instance.new("Frame")
    local sz = (i % 3 == 0) and 3 or 2
    s.Size             = UDim2.new(0, sz, 0, sz)
    s.Position         = UDim2.new(math.random(2,96)/100, 0, math.random(2,96)/100, 0)
    s.BackgroundColor3 = Color3.new(1,1,1)
    local baseT        = math.random(1,4)/10 + 0.1
    s.BackgroundTransparency = baseT
    s.BorderSizePixel  = 0
    s.ZIndex           = 2
    s.Parent           = main
    Instance.new("UICorner", s).CornerRadius = UDim.new(1,0)
    table.insert(starList, {f = s, base = baseT})
end
for i, sd in ipairs(starList) do
    task.delay(i * 0.11, function()
        while true do
            TweenService:Create(sd.f, TweenInfo.new(math.random(12,30)/10, Enum.EasingStyle.Sine), {BackgroundTransparency = math.min(sd.base+0.55, 0.96)}):Play()
            task.wait(math.random(12,30)/10)
            TweenService:Create(sd.f, TweenInfo.new(math.random(12,30)/10, Enum.EasingStyle.Sine), {BackgroundTransparency = sd.base}):Play()
            task.wait(math.random(12,30)/10)
        end
    end)
end

-- Drifting orbs
local orbCols = {Color3.fromRGB(140,80,255), Color3.fromRGB(60,140,255), Color3.fromRGB(200,100,255), Color3.fromRGB(80,200,255)}
for i = 1, 4 do
    local orb = Instance.new("Frame")
    orb.Size             = UDim2.new(0, math.random(4,7), 0, math.random(4,7))
    orb.Position         = UDim2.new(math.random(10,90)/100, 0, math.random(10,90)/100, 0)
    orb.BackgroundColor3 = orbCols[i]
    orb.BackgroundTransparency = 0.25
    orb.BorderSizePixel  = 0
    orb.ZIndex           = 2
    orb.Parent           = main
    Instance.new("UICorner", orb).CornerRadius = UDim.new(1,0)
    task.delay(i*0.4, function()
        while true do
            TweenService:Create(orb, TweenInfo.new(math.random(50,110)/10, Enum.EasingStyle.Sine), {Position = UDim2.new(math.random(5,90)/100, 0, math.random(5,90)/100, 0)}):Play()
            task.wait(math.random(50,110)/10)
        end
    end)
end

