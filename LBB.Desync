creditLbl.Font=Enum.Font.Gotham; creditLbl.ZIndex=20; creditLbl.Parent=main

--==================================================
-- UPDATE UI
--==================================================
local function updateUI()
    if desynced then
        statusDot.BackgroundColor3=Color3.fromRGB(255,70,70)
        statusLbl.Text="ACTIVE"; statusLbl.TextColor3=Color3.fromRGB(255,70,70)
        toggleBtn.Text="DEACTIVATE DESYNC"
        btnBg.BackgroundColor3=Color3.fromRGB(110,15,35)
        btnStroke.Color=Color3.fromRGB(255,60,80)
        mainBorder.Color=Color3.fromRGB(220,40,70)
        glowPurple.ImageColor3=Color3.fromRGB(180,20,50)
        snapBg.BackgroundColor3=Color3.fromRGB(15,55,35)
        snapStroke.Color=Color3.fromRGB(50,180,90)
        snapBtn.TextColor3=Color3.fromRGB(80,255,140)
    else
        statusDot.BackgroundColor3=Color3.fromRGB(80,220,120)
        statusLbl.Text="INACTIVE"; statusLbl.TextColor3=Color3.fromRGB(80,220,120)
        if supported then
            toggleBtn.Text="ACTIVATE DESYNC"; toggleBtn.TextColor3=Color3.new(1,1,1)
            btnBg.BackgroundColor3=Color3.fromRGB(55,25,130)
            btnStroke.Color=Color3.fromRGB(120,70,255)
            subLbl.Text="RAKNET · READY ✅"; subLbl.TextColor3=Color3.fromRGB(100,75,210)
        else
            toggleBtn.Text="RAKNET NOT FOUND"; toggleBtn.TextColor3=Color3.fromRGB(140,140,140)
            btnBg.BackgroundColor3=Color3.fromRGB(40,40,40)
            btnStroke.Color=Color3.fromRGB(80,80,80)
            subLbl.Text="RAKNET · NOT FOUND ❌"; subLbl.TextColor3=Color3.fromRGB(255,80,80)
        end
        mainBorder.Color=Color3.fromRGB(90,50,200)
        glowPurple.ImageColor3=Color3.fromRGB(100,40,220)
        snapBg.BackgroundColor3=Color3.fromRGB(15,55,35)
        snapStroke.Color=Color3.fromRGB(50,180,90)
        snapBtn.TextColor3=Color3.fromRGB(80,255,140)
    end
end

--==================================================
-- RAKNET DETECTION
--==================================================
task.spawn(function()
    task.wait(0.2)
    pcall(function()
        local envs={}
        pcall(function() envs[#envs+1]=getgenv() end)
        pcall(function() envs[#envs+1]=getrenv() end)
        pcall(function() envs[#envs+1]=getfenv() end)
        pcall(function() envs[#envs+1]=_G end)

        print("[LBB] === RAKNET SEARCH ===")
        for i,env in ipairs(envs) do
            local ename=({"getgenv","getrenv","getfenv","_G"})[i] or "?"
            pcall(function()
                for k,v in pairs(env) do
                    local ks=tostring(k):lower()
                    if ks:find("rak") or ks:find("desync") or ks:find("packet") then
                        print("[LBB]["..ename.."] "..tostring(k).." = "..type(v))
                        if type(v)=="table" then
                            pcall(function() for k2,v2 in pairs(v) do print("  ."..tostring(k2).." = "..type(v2)) end end)
                        end
                    end
                end
            end)
        end
        print("[LBB] === END SEARCH ===")

        -- raknet table (Delta)
        for _,env in ipairs(envs) do
            pcall(function()
                local rn=env.raknet
                if type(rn)~="table" then return end
                if type(rn.desync)=="table" then
                    local d=rn.desync
                    _pause=d.pause or d.Pause or d.enable or d.Enable
                    _resume=d.resume or d.Resume or d.disable or d.Disable
                elseif type(rn.desync)=="function" then
                    _pause=function() rn.desync(true)  end
                    _resume=function() rn.desync(false) end
                elseif type(rn.pause)=="function" then
                    _pause=rn.pause; _resume=rn.resume
                elseif type(rn.Pause)=="function" then
                    _pause=function() rn:Pause() end; _resume=function() rn:Resume() end
                end
            end)
            if _pause then print("[LBB] Found via raknet table"); break end
        end

        -- Flat globals
        if not _pause then
            for _,env in ipairs(envs) do
                pcall(function()
                    for _,name in ipairs({"raknetpause","RakNetPause","raknet_pause","pauseraknet"}) do
                        if type(env[name])=="function" then _pause=env[name]; print("[LBB] pause: "..name); break end
                    end
                end)
                if _pause then break end
            end
        end
        if not _resume then
            for _,env in ipairs(envs) do
                pcall(function()
                    for _,name in ipairs({"raknetresume","RakNetResume","raknet_resume","resumeraknet"}) do
                        if type(env[name])=="function" then _resume=env[name]; print("[LBB] resume: "..name); break end
                    end
                end)
                if _resume then break end
            end
        end

        -- Direct fallbacks
        if not _pause  then pcall(function() if type(raknetpause) =="function" then _pause =raknetpause  end end) end
        if not _resume then pcall(function() if type(raknetresume)=="function" then _resume=raknetresume end end) end

        supported=type(_pause)=="function" and type(_resume)=="function"
        print("[LBB] RakNet supported: "..tostring(supported))
        updateUI()
    end)
end)

--==================================================
-- PAUSE / RESUME
--==================================================
local function pauseNet()
    if desynced or not supported then return end
    local ok,err=pcall(_pause)
    if ok then desynced=true; print("[LBB] DESYNCED")
    else warn("[LBB] pause failed: "..tostring(err)) end
end

local function resumeNet()
    if not desynced then return end
    pcall(_resume); desynced=false; print("[LBB] RESYNCED")
end

player.CharacterAdded:Connect(function(c)
    character=c
    if desynced then pcall(function() if _resume then _resume() end end); desynced=false end
    updateUI()
end)

--==================================================
-- SNAP & ACT
-- Resume → fire all nearby interactions → re-pause
-- Server receives the interaction before processing
-- the queued position packets
--==================================================
local function snapAndAct()
    if not supported then return end
    if not desynced then
        warn("[LBB] Snap & Act only works while desynced"); return
    end

    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Resume for ONE frame so server gets our real position
    pcall(_resume)
    desynced = false

    -- Fire interactions at current client position
    task.spawn(function()
        -- Click all nearby ClickDetectors
        pcall(function()
            for _,obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("ClickDetector") then
                    local part = obj.Parent
                    if part and part:IsA("BasePart") then
                        local dist = (hrp.Position - part.Position).Magnitude
                        if dist <= (obj.MaxActivationDistance + 10) then
                            pcall(function() fireclickdetector(obj) end)
                        end
                    end
                end
            end
        end)

        -- Fire ProximityPrompts nearby
        pcall(function()
            for _,obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    local part = obj.Parent
                    if part and part:IsA("BasePart") then
                        local dist = (hrp.Position - part.Position).Magnitude
                        if dist <= (obj.MaxActivationDistance + 5) then
                            pcall(function() fireproximityprompt(obj) end)
                        end
                    end
                end
            end
        end)
    end)

    -- Wait 2 frames for server to receive interaction, then re-pause
    task.wait()
    task.wait()

    pcall(_pause)
    desynced = true
    updateUI()
    print("[LBB] Snap & Act fired, re-paused")
end

--==================================================
-- BUTTONS
--==================================================
local function bounce(bg, origSize, origPos)
    TweenService:Create(bg,TweenInfo.new(0.07,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
        {Size=UDim2.new(0,origSize.X.Offset-8,0,origSize.Y.Offset-4),
         Position=UDim2.new(origPos.X.Scale,origPos.X.Offset+4,origPos.Y.Scale,origPos.Y.Offset+2)}):Play()
    task.delay(0.07,function()
        TweenService:Create(bg,TweenInfo.new(0.14,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
            {Size=origSize,Position=origPos}):Play()
    end)
end

toggleBtn.MouseButton1Click:Connect(function()
    if not supported then warn("[LBB] RakNet unavailable"); return end
    bounce(btnBg, btnBg.Size, btnBg.Position)
    if desynced then resumeNet() else pauseNet() end
    updateUI()
end)

snapBtn.MouseButton1Click:Connect(function()
    bounce(snapBg, snapBg.Size, snapBg.Position)
    snapAndAct()
end)

--==================================================
-- DRAGGABLE — header only
--==================================================
local dragging,dragStart,startPos
header.InputBegan:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 then
        dragging=true; dragStart=input.Position; startPos=main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType==Enum.UserInputType.MouseMovement then
        local d=input.Position-dragStart
        main.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
end)

--==================================================
-- KEYBINDS
--==================================================
UserInputService.InputBegan:Connect(function(input,gp)
    if listeningFor then
        if input.UserInputType==Enum.UserInputType.Keyboard then
            keybinds[listeningFor]=input.KeyCode
            local ref=keyBtnRefs[listeningFor]
            if ref then
                ref.badge.Text=input.KeyCode.Name
                ref.badge.TextColor3=Color3.new(1,1,1)
                ref.stroke.Color=Color3.fromRGB(70,45,145)
            end
            listeningFor=nil
        end
        return
    end
    if gp then return end
    if input.KeyCode==keybinds.toggle then
        if desynced then resumeNet() else pauseNet() end; updateUI()
    elseif input.KeyCode==keybinds.snap then
        snapAndAct()
    elseif input.KeyCode==keybinds.panel then
        gui.Enabled=not gui.Enabled
    end
end)

-- Safety: auto resume on death
RunService.Heartbeat:Connect(function()
    if not desynced then return end
    local char=player.Character; if not char then return end
    local hum=char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health<=0 then resumeNet(); updateUI() end
end)

print("🌌 LBB Desync loaded")
