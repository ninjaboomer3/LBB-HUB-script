-- Keybind rows
local keyBtnRefs={}
local function makeKeyRow(labelText,bindKey,posY)
    local row=Instance.new("Frame")
    row.Size=UDim2.new(0,220,0,32); row.Position=UDim2.new(0.5,-110,0,posY)
    row.BackgroundColor3=Color3.fromRGB(10,7,28)
    row.BorderSizePixel=0; row.ZIndex=20; row.Parent=main
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,9)
    local rs=Instance.new("UIStroke"); rs.Color=Color3.fromRGB(40,25,85); rs.Thickness=1; rs.Parent=row
    local lbl=Instance.new("TextLabel")
    lbl.Size=UDim2.new(0.55,0,1,0); lbl.Position=UDim2.new(0,10,0,0)
    lbl.BackgroundTransparency=1; lbl.Text=labelText
    lbl.TextColor3=Color3.fromRGB(140,120,200); lbl.Font=Enum.Font.Gotham
    lbl.TextScaled=true; lbl.TextXAlignment=Enum.TextXAlignment.Left
    lbl.ZIndex=21; lbl.Parent=row
    local badge=Instance.new("TextButton")
    badge.Size=UDim2.new(0.37,0,0.65,0); badge.Position=UDim2.new(0.6,0,0.175,0)
    badge.BackgroundColor3=Color3.fromRGB(28,16,68)
    badge.TextColor3=Color3.new(1,1,1); badge.Text=keybinds[bindKey].Name
    badge.TextScaled=true; badge.Font=Enum.Font.GothamBold
    badge.BorderSizePixel=0; badge.ZIndex=22; badge.Parent=row
    Instance.new("UICorner",badge).CornerRadius=UDim.new(0,7)
    local bs=Instance.new("UIStroke"); bs.Color=Color3.fromRGB(70,45,145); bs.Thickness=1; bs.Parent=badge
    badge.MouseButton1Click:Connect(function()
        if listeningFor then return end
        listeningFor=bindKey; badge.Text="..."
        badge.TextColor3=Color3.fromRGB(255,215,60); bs.Color=Color3.fromRGB(255,200,40)
    end)
    keyBtnRefs[bindKey]={badge=badge,stroke=bs}
end
makeKeyRow("TOGGLE DESYNC","toggle",210)
makeKeyRow("SNAP & ACT","snap",248)
makeKeyRow("HIDE PANEL","panel",286)

