gui.Name = "LBBDesync"
gui.ResetOnSpawn = false
gui.DisplayOrder = 99999
gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
gui.Enabled = true
gui.Parent = player:WaitForChild("PlayerGui")

-- Background canvas (no ClipsDescendants so nothing gets cut)
