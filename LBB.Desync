--==================================================
-- UPDATE UI
--==================================================
function updateUI()
    if desynced then
        -- Red/hot state
        statusDot.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
        statusLabel.Text = "ACTIVE"
        statusLabel.TextColor3 = Color3.fromRGB(255, 70, 70)
        toggleBtn.Text = "DEACTIVATE DESYNC"
        btnOuter.BackgroundColor3 = Color3.fromRGB(120, 20, 40)
        btnStroke.Color = Color3.fromRGB(255, 80, 80)
        border.Color = Color3.fromRGB(220, 50, 80)
        glowA.ImageColor3 = Color3.fromRGB(180, 30, 60)
    else
        -- Purple/galaxy state
        statusDot.BackgroundColor3 = Color3.fromRGB(80, 220, 120)
        statusLabel.Text = "INACTIVE"
        statusLabel.TextColor3 = Color3.fromRGB(80, 220, 120)
        toggleBtn.Text = "ACTIVATE DESYNC"
        btnOuter.BackgroundColor3 = Color3.fromRGB(60, 30, 130)
        btnStroke.Color = Color3.fromRGB(120, 70, 255)
        border.Color = Color3.fromRGB(80, 40, 180)
        glowA.ImageColor3 = Color3.fromRGB(100, 40, 220)
    end
end

updateUI()

-- Button pulse animation on click
toggleBtn.MouseButton1Click:Connect(function()
    local t = TweenService:Create(btnOuter,
        TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {Size = UDim2.new(0, 192, 0, 48)}
    )
    t:Play()
    t.Completed:Connect(function()
        TweenService:Create(btnOuter,
            TweenInfo.new(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
            {Size = UDim2.new(0, 200, 0, 52)}
        ):Play()
    end)
    if desynced then resumeNet() else pauseNet() end
    updateUI()
end)

--==================================================
-- DRAGGABLE
--==================================================
local dragging, dragStart, startPos
main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

--==================================================
-- KEYBINDS
--==================================================
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.H then
        if desynced then resumeNet() else pauseNet() end
        updateUI()
    elseif input.KeyCode == Enum.KeyCode.U then
        gui.Enabled = not gui.Enabled
    end
end)

--==================================================
-- SAFETY: auto resume on death
--==================================================
RunService.Heartbeat:Connect(function()
    if not desynced then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health <= 0 then
        resumeNet()
        updateUI()
    end
end)

print("🌌 LBB Desync — Galaxy Edition loaded. H = toggle | U = panel")
