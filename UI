local toggled = {}
local createdButtons = {}

local function createButton(gui)
    if createdButtons[gui] then return end
    createdButtons[gui] = true

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1,0,0,35)
    button.BackgroundColor3 = Color3.fromRGB(50,50,65)
    button.TextColor3 = Color3.new(1,1,1)
    button.TextScaled = true
    button.Font = Enum.Font.Gotham
    button.BorderSizePixel = 0
    button.Parent = scroll
    Instance.new("UICorner", button).CornerRadius = UDim.new(0,8)

    local function update()
        local on = toggled[gui]
        button.BackgroundColor3 = on and Color3.fromRGB(40,100,40) or Color3.fromRGB(50,50,65)
        button.Text = gui.Name .. (on and " [REVEALED]" or " [OFF]")
    end

    button.MouseButton1Click:Connect(function()
        if not toggled[gui] then
            toggled[gui] = true
            lockGui(gui)
            triggerInteractions(gui.Name)
            -- Re-reveal a few times to catch delayed show/hide logic
            task.spawn(function()
                for _ = 1, 10 do
                    task.wait(0.3)
                    if toggled[gui] then deepGentleReveal(gui) end
                end
            end)
        else
            toggled[gui] = false
            unlockGui(gui)
        end
        update()
    end)

    update()
end

local function populate()
    for _, gui in ipairs(PlayerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui ~= panel then
            createButton(gui)
        end
    end
end

populate()

PlayerGui.ChildAdded:Connect(function(child)
    if child:IsA("ScreenGui") and child ~= panel then
        task.wait(); createButton(child)
    end
end)

-- Heartbeat: gentle only, and throttled to every 0.1s instead of every frame
local hbTimer = 0
RunService.Heartbeat:Connect(function(dt)
    hbTimer += dt
    if hbTimer < 0.1 then return end
    hbTimer = 0
    for gui, isOn in pairs(toggled) do
        if isOn and gui and gui.Parent then
            deepGentleReveal(gui)
        end
    end
end)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.U then
        panel.Enabled = not panel.Enabled
    end
end)

print("🟢 Ultimate UI Revealer — Gentle Edition loaded.")
